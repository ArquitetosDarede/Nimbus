# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Nimbus local Notion cache (SQLite mirror — do not commit)
.nimbus_cache/

# Scratch/test scripts — isolated, safe to delete
_scratch/

# IDE settings (keep project-specific VS Code configs tracked if needed)
.vscode/*.log

# Old proposals 
propostas/

